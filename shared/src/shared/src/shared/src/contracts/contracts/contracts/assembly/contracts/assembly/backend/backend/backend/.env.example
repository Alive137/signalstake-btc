# SignalStake BTC — Backend Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

OPNET_NETWORK=testnet
PORT=3001

# Contract address (set after deploying via opnet-cli)
CONTRACT_ADDRESS=REPLACE_AFTER_DEPLOY

# Optional: backend wallet for signing
# WALLET_WIF=your_wif_private_key_here
# MLDSA_PRIVATE_KEY=your_mldsa_key_here
